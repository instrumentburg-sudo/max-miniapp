# Add these location blocks inside the instrumentburg.ru server block
# File: /etc/nginx/sites-available/instrumentburg.ru (or equivalent on NetAngels)

# MAX Mini App — static frontend
location /max-app/ {
    alias /home/c50684/instrumentburg.ru/www/max-app/;
    try_files $uri $uri/ /max-app/index.html;
    expires 7d;
    add_header Cache-Control "public, immutable";
}

# MAX Mini App — API proxy
location /max-api/ {
    proxy_pass http://127.0.0.1:8100/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 30s;
}
